<com.google.android.material.card.MaterialCardView
    android:id="@+id/rootCard"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_margin="8dp"
    android:layout_width="match_parent"
    android:layout_height="120dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"> <!-- REMOVE BLACK BORDER -->

    <RelativeLayout
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Circle Background -->
        <View
            android:id="@+id/circleBg"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_circle"/>

        <!-- Product Image -->
        <ImageView
            android:id="@+id/img"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="10dp"
            android:layout_alignStart="@id/circleBg"
            android:scaleType="centerCrop"/>

        <!-- Product Name -->
        <TextView
            android:id="@+id/name"
            android:layout_toEndOf="@id/circleBg"
            android:layout_marginStart="16dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/bricolagegrotesquelight"
            android:textColor="@color/product"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Price -->
        <TextView
            android:id="@+id/price"
            android:layout_below="@id/name"
            android:layout_toEndOf="@id/circleBg"
            android:layout_marginStart="16dp"
            android:layout_marginTop="2dp"
            android:text="₹0"
            android:textSize="14sp"
            android:fontFamily="@font/bricolagegrotesquelight"
            android:textColor="@color/product"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Favorite Icon -->
        <ImageView
            android:id="@+id/btnFav"
            android:src="@drawable/favorite_filled"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="10dp"
            android:layout_marginTop="5dp"
            android:layout_width="24dp"
            android:layout_height="24dp"/>

        <!-- Add to Cart Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCart"
            android:layout_width="140dp"
            android:layout_height="40dp"
            android:layout_below="@id/price"
            android:layout_toEndOf="@id/circleBg"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:text="Add to Cart"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:fontFamily="@font/bricolagegrotesquelight"
            app:backgroundTint="@color/green_primary"
            app:cornerRadius="25dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>