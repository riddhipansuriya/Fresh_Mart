<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ✅ MAIN CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_above="@id/bottomNav">

        <!-- ✅ SCROLLABLE CONTENT -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F5F5F5"
                android:paddingBottom="90dp">

                <!-- 🔍 SEARCH BOX -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:background="@drawable/search_box"
                    android:gravity="center"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/search_bg"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="15dp"
                        android:paddingEnd="10dp">

                        <EditText
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Search Food, Drinks, and more"
                            android:textSize="18sp"
                            android:fontFamily="@font/buda"
                            android:textColor="#000000"
                            android:textColorHint="#888888"
                            android:background="@null"/>

                        <LinearLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/search_circle"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:src="@drawable/search_icon"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>

                <!-- 🔥 BANNER -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="350dp"
                        android:layout_height="180dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/banner_bg"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="160dp"
                            android:layout_height="160dp"
                            android:src="@drawable/basket"
                            android:scaleType="fitCenter"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="10dp">

                            <TextView
                                android:text="Get 20% Off"
                                android:textColor="#2F6F9F"
                                android:textSize="26sp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:text="Enjoy offer on fruits and veggies"
                                android:textColor="#666"
                                android:textSize="15sp"
                                android:layout_marginTop="4dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/shopNow"
                                android:layout_width="140dp"
                                android:layout_height="45dp"
                                android:text="SHOP NOW"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:layout_marginTop="10dp"
                                android:backgroundTint="#2B6D9E"
                                app:cornerRadius="10dp"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>

                <!-- 📦 CATEGORIES -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerCategories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:paddingStart="10dp"
                    android:clipToPadding="false"/>

                <!-- 🛒 PRODUCTS -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerProducts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:paddingStart="10dp"
                    android:clipToPadding="false"/>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

    <!-- ✅ FIXED BOTTOM NAV -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"

        app:menu="@menu/bottom_menu"
        app:itemIconTint="@null"
        app:itemTextColor="@color/search"
        app:labelVisibilityMode="labeled"
        app:itemIconSize="26dp"/>

</RelativeLayout>